{
  "name": "@duckstech/provider-bypass",
  "version": "0.2.0",
  "description": "Direct API access to Claude and ChatGPT using local CLI credentials. No API keys needed.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "codex",
    "chatgpt",
    "anthropic",
    "openai",
    "provider",
    "bypass",
    "oauth",
    "api",
    "llm"
  ],
  "author": "ducks",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@10.27.0",
  "dependencies": {
    "nanoid": "^5.1.7",
    "p-queue": "^9.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "sideEffects": false,
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
